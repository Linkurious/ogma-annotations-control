{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../node_modules/@linkurious/eslint-config-ogma/.oxlintrc.json"],
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
