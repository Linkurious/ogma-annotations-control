{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../node_modules/@linkurious/eslint-config-ogma/.oxlintrc.json"],
  "plugins": ["react"],
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "react/exhaustive-deps": "warn",
    "react/rules-of-hooks": "error"
  }
}
